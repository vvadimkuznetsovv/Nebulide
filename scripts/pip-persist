#!/bin/bash
# Wrapper around "pip install" that uses the persistent venv.
# Usage: pip-persist numpy pandas flask
# The venv lives in /home/nebulide/workspace/.venv (survives deploys).

VENV_DIR="/home/nebulide/workspace/.venv"

if [ $# -eq 0 ]; then
  echo "Usage: pip-persist <package1> [package2] ..."
  exit 1
fi

# Ensure venv exists
if [ ! -d "$VENV_DIR" ]; then
  python3 -m venv "$VENV_DIR"
fi

# Install into the persistent venv
"$VENV_DIR/bin/pip" install "$@"

echo "Packages installed into persistent venv: $*"
echo "Venv auto-activates in new terminal sessions."
