# Server
PORT=8080
GIN_MODE=release

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nebulide
DB_PASSWORD=change_me_strong_password
DB_NAME=nebulide

# JWT
JWT_SECRET=change_me_random_64_char_string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Redis
REDIS_URL=localhost:6379

# Security
ALLOWED_ORIGINS=https://nebulide.ru

# Claude Code
CLAUDE_ALLOWED_TOOLS=Read,Edit,Write,Bash,Glob,Grep
CLAUDE_WORKING_DIR=/home/nebulide/workspace
CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000
ANTHROPIC_API_KEY=sk-ant-xxxxx

# GLM (Z.ai) — провайдер для запуска claude на GLM 5.2 вместо Anthropic.
# Ключ берётся в GLM Coding Plan на https://z.ai/subscribe (Anthropic-совместимый эндпоинт).
# Пусто => режим «Z» в UI тихо недоступен (терминал падает на Anthropic).
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/anthropic
# [1m] = 1M контекста (без суффикса ~200K). Бэк сам поднимет окно авто-компакта до 1M.
ZAI_MODEL=glm-5.2[1m]
# Бесплатный usage-эндпоинт Z.ai (% лимита + время сброса, БЕЗ траты промпта) — для индикатора на кнопке «Z».
ZAI_USAGE_URL=https://api.z.ai/api/monitor/usage/quota/limit

# Admin (first user seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
